# Connect to Supabase via connection pooling with Supavisor.
DATABASE_URL="postgres://postgres.[YOUR_DATABASE]:[YOUR_PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection to the database. Used for migrations.
DIRECT_URL="postgres://postgres.[YOUR_DATABASE]:[YOUR_PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres"

# Better Auth
BETTER_AUTH_SECRET="secret_key"
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# UploadThing — get token from https://uploadthing.com/dashboard
UPLOADTHING_TOKEN=""

# Google OAuth — create credentials at https://console.cloud.google.com/
# Authorized redirect URI: {NEXT_PUBLIC_BASE_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Redis — for real-time offer chat (SSE pub/sub)
REDIS_URL="redis://localhost:6379"

# SMTP — nodemailer transactional email (offer notifications)
# Works with any SMTP provider: Gmail, Mailpit (dev), Brevo, Postmark, etc.
# Leave blank to disable email sending (notifications still work in-app).
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Landil <no-reply@landil.app>"